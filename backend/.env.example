# Configurações do Servidor
PORT=5000

# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_multitenant
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Configurações de Autenticação JWT
JWT_SECRET=sua_chave_secreta_muito_segura_troque_isso_em_producao
JWT_EXPIRES_IN=7d

# Configurações de Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880